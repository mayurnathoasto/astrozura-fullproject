login api/public/test_search.php

# Laravel specifics
login api/storage/*.key
login api/storage/framework/cache/data/*
login api/storage/framework/sessions/*
login api/storage/framework/testing/*
login api/storage/framework/views/*
login api/storage/logs/*.log
login api/auth.json

# IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

